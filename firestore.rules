rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    // Helper functions for validating crowd congestion status updates
    function isValidSectorData(data) {
      return data.status is string && 
             data.status in ['low', 'medium', 'high'] &&
             data.updatedAt is string;
    }

    function isValidCongestionUpdate() {
      let allowedSectors = [
        'North Gate', 'South Gate', 'East Stand', 
        'West VIP Lounge', 'Metro Connection Hub', 'Bus Shuttle Link'
      ];
      let keys = request.resource.data.keys();
      
      // Ensure only allowed sector keys can be updated/written
      let keysValid = keys.hasOnly(allowedSectors);
      
      // Check validation constraints for each sector if present in the data keys
      let isNorthValid = !('North Gate' in request.resource.data) || isValidSectorData(request.resource.data['North Gate']);
      let isSouthValid = !('South Gate' in request.resource.data) || isValidSectorData(request.resource.data['South Gate']);
      let isEastValid = !('East Stand' in request.resource.data) || isValidSectorData(request.resource.data['East Stand']);
      let isWestValid = !('West VIP Lounge' in request.resource.data) || isValidSectorData(request.resource.data['West VIP Lounge']);
      let isMetroValid = !('Metro Connection Hub' in request.resource.data) || isValidSectorData(request.resource.data['Metro Connection Hub']);
      let isBusValid = !('Bus Shuttle Link' in request.resource.data) || isValidSectorData(request.resource.data['Bus Shuttle Link']);
      
      return keysValid && isNorthValid && isSouthValid && isEastValid && isWestValid && isMetroValid && isBusValid;
    }

    /*
     * Validation Logic for Crowd Congestion updates:
     * - Reads: Open to any authenticated user.
     * - Writes: Must be authenticated and strictly validated to prevent garbage data injection:
     *   (a) Incoming keys must be a subset of known sectors ('North Gate', 'South Gate', etc.).
     *   (b) Each sector's status must be exactly 'low', 'medium', or 'high'.
     *   (c) Each sector's updatedAt must be a valid string timestamp.
     */
    match /congestion/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isValidCongestionUpdate();
    }
  }
}
